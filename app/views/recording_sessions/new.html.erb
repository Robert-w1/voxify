<div class="container-app py-5">

  <%# ── Page header (left-aligned, matches Sessions / Folders) ── %>
  <div class="session-new-content mb-5">
    <h1 class="mb-1">New session</h1>
    <p class="text-caption fst-italic mb-0">Record yourself, get AI feedback, and track your progress session by session.</p>
  </div>

  <%# ── Form — centered, constrained width ── %>
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <%= form_with(
        model: @recording_session,
        html: { class: "session-form" },
        data: { controller: "session-form", action: "change->session-form#validate" }
      ) do |f| %>

        <% if @recording_session.errors.any? %>
          <div class="p-3 mb-4" style="background-color: #f8d7da; border: 1px solid #912519; border-radius: 10px; color: #912519;">
            <% @recording_session.errors.full_messages.each do |msg| %>
              <p class="mb-0"><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <%# ── Section label ── %>
        <p class="session-new-goal-label mb-4">Set the goal for your session</p>

        <%# ── STEP INDICATOR ── %>
        <div class="flow-steps mb-4">
          <button type="button" class="flow-step active"
                  data-session-form-target="stepDot"
                  data-step="1"
                  data-action="click->session-form#goToStep">
            <span class="step-num">1</span>
            <span class="step-label">Practice</span>
          </button>
          <div class="flow-step-line"></div>
          <button type="button" class="flow-step locked"
                  data-session-form-target="stepDot"
                  data-step="2"
                  data-action="click->session-form#goToStep">
            <span class="step-num">2</span>
            <span class="step-label">Audience</span>
          </button>
          <div class="flow-step-line"></div>
          <button type="button" class="flow-step locked"
                  data-session-form-target="stepDot"
                  data-step="3"
                  data-action="click->session-form#goToStep">
            <span class="step-num">3</span>
            <span class="step-label">Focus</span>
          </button>
        </div>

        <%# ── CARD 1: PRESENTATION TYPE ── %>
        <div class="flow-card" data-session-form-target="card" data-step="1">
          <h5 class="fw-semibold mb-1">What are you practicing?</h5>
          <p class="text-caption fst-italic mb-4">Choose one core purpose.</p>
          <div class="option-grid">
            <% RecordingSession::PRESENTATION_TYPE_OPTIONS.each do |option| %>
              <div>
                <%= f.radio_button :presentation_type, option,
                  class: "btn-check",
                  id: "presentation_type_#{option}",
                  data: { session_form_target: "requiredField", action: "click->session-form#toggleRadio" } %>
                <%= f.label :presentation_type, option.humanize.gsub("1on1", "1-on-1"),
                  for: "presentation_type_#{option}",
                  class: "btn btn-option" %>
              </div>
            <% end %>
          </div>
        </div>

        <%# ── CARD 2: AUDIENCE ── %>
        <div class="flow-card" data-session-form-target="card" data-step="2" hidden>
          <h5 class="fw-semibold mb-1">Who is the audience?</h5>
          <p class="text-caption fst-italic mb-4">Choose one core audience.</p>
          <div class="option-grid">
            <% RecordingSession::AUDIENCE_OPTIONS.each do |option| %>
              <div>
                <%= f.radio_button :audience, option,
                  class: "btn-check",
                  id: "audience_#{option}",
                  data: { session_form_target: "requiredField", action: "click->session-form#toggleRadio" } %>
                <%= f.label :audience, option.humanize,
                  for: "audience_#{option}",
                  class: "btn btn-option" %>
              </div>
            <% end %>
          </div>
        </div>

        <%# ── CARD 3: FEEDBACK FOCUS ── %>
        <div class="flow-card" data-session-form-target="card" data-step="3" hidden>
          <h5 class="fw-semibold mb-1">What is your desired feedback focus?</h5>
          <p class="text-caption fst-italic mb-4">Optionally choose areas to focus your AI feedback report.</p>
          <div class="option-grid">
            <% RecordingSession::FEEDBACK_FOCUS_OPTIONS.each do |option| %>
              <div>
                <%= f.check_box :focus, {
                  multiple: true,
                  class: "btn-check",
                  id: "focus_#{option}",
                  data: { session_form_target: "checkboxField" }
                }, option, nil %>
                <%= f.label :focus, option.humanize,
                  for: "focus_#{option}",
                  class: "btn btn-option" %>
              </div>
            <% end %>
          </div>
        </div>

        <%# ── CARD NAVIGATION ── %>
        <div class="flow-nav">
          <button type="button"
                  class="btn btn-secondary"
                  data-session-form-target="prevButton"
                  data-action="click->session-form#prevStep"
                  hidden>
            &larr; Previous
          </button>

          <div class="ms-auto text-end" style="position: relative;">
            <%# Steps 1 & 2 %>
            <button type="button"
                    class="btn btn-primary"
                    data-session-form-target="nextButton"
                    data-action="click->session-form#nextStep">
              Next &rarr;
            </button>

            <%# Step 3 — submit acts as Next %>
            <div data-session-form-target="submitWrapper" hidden>
              <div data-action="click->session-form#attemptSubmit">
                <%= f.submit "Next \u2192",
                  class: "btn btn-primary",
                  disabled: true,
                  data: { session_form_target: "submitButton", turbo: false } %>
              </div>
              <p class="text-caption fst-italic mb-0" style="display: none; position: absolute; right: 0; top: 100%; margin-top: 4px; white-space: nowrap;" data-session-form-target="warningMessage">
                Please select a presentation type and audience before starting.
              </p>
            </div>

            <p class="text-caption fst-italic mb-0" style="display: none; position: absolute; right: 0; top: 100%; margin-top: 4px; white-space: nowrap;" data-session-form-target="selectionWarning">
              Please make a selection to proceed
            </p>
          </div>
        </div>

      <% end %>
    </div>
  </div>

</div>
