<div class="auth-page auth-page--with-footer">
  <div class="auth-card p-5">
    <h1>Sign in</h1>
    <p>Already have an account? <%= render "devise/shared/links" %></p>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: flash[:alert].present? ? "auth-failed" : nil }) do |f| %>
        <div class="form-inputs">
          <%= f.input :email,
                      required: false,
                      autofocus: true,
                      input_html: { autocomplete: "email", class: "input-field", pattern: '[^@\s]+@[^@\s]+\.[^@\s]+', title: "Please enter a valid email (e.g. you@example.com)" } %>
          <%= f.input :password,
                      required: false,
                      input_html: { autocomplete: "new-password", class: "input-field" } %>
          <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
        </div>

        <div class="form-actions">
          <%= f.button :submit, "Sign in", class: "btn btn-primary me-2" %>
          <%= link_to "Cancel", root_path, class: "btn btn-secondary"  %>
        </div>
      <% end %>
  </div>
</div>

<footer class="vx-footer py-4">
  <div class="vx-footer__inner px-4 justify-content-center">
    <p class="vx-footer__copy">&copy; <%= Date.current.year %> Voxify. All rights reserved.</p>
  </div>
</footer>
