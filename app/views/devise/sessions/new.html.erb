<div class="auth-page">
  <div class="auth-card p-5">
    <h1>Sign in</h1>
    <p>Already have an account? <%= render "devise/shared/links" %></p>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="form-inputs">
          <%= f.input :email,
                      required: false,
                      autofocus: true,
                      input_html: { autocomplete: "name", class: "input-field" } %>
          <%= f.input :password,
                      required: false,
                      input_html: { autocomplete: "new-password", class: "input-field" } %>
          <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
        </div>

        <div class="form-actions">
          <%= f.button :submit, "Sign in", class: "btn btn-primary me-2" %>
          <%= link_to "Cancel", root_path, class: "btn btn-secondary"  %>
        </div>
      <% end %>
  </div>
</div>
