<div class="auth-page">
  <div class="auth-card p-5">
    <h1>Sign up</h1>
    <p>Already have an account? <%= render "devise/shared/links" %></p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :username,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "name", class: "input-field" } %>
        <%= f.input :email,
                    required: true,
                    input_html: { autocomplete: "email", class: "input-field" } %>
        <%= f.input :password,
                    required: true,
                    hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password", class: "input-field" } %>
        <%= f.input :password_confirmation,
                    required: true,
                    input_html: { autocomplete: "new-password", class: "input-field" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Sign up", class: "btn btn-primary me-2" %>
        <%= link_to "Cancel", root_path, class: "btn btn-secondary"  %>
      </div>
    <% end %>
  </div>
</div>
