<%# ============================================================
<%#    Voxify Sidebar %>
<%#    - Collapses to icon-only mode via JS toggle
<%#    - Recent sessions pulled from @recent_sessions (set in controller)
<%#    - Avatar dropdown for logout
<%# ============================================================ %>
<aside id="sidebar" class="sidebar">

  <div class="sidebar-top">

    <%# ── Header: logo + collapse toggle ── %>
    <div class="sidebar-header">
      <div class="brand-link">
        <%= image_tag "voxify_logo.svg", class: "brand-logo", alt: "Voxify" %>
        <span class="brand-name">Voxify</span>
      </div>
      <button id="sidebar-toggle" class="toggle-btn" aria-label="Toggle sidebar">
        <i data-feather="menu"></i>
      </button>
    </div>

    <%# ── Primary navigation ── %>
    <nav class="sidebar-nav">

      <%# Search %>
      <div data-controller="sidebar-search" class="sidebar-search-container">

        <div class="nav-item sidebar-search-trigger"
             data-action="click->sidebar-search#activate"
             data-sidebar-search-target="trigger">
          <i data-feather="search"></i>
          <span class="label">Search</span>
        </div>

        <div class="sidebar-search-active" hidden data-sidebar-search-target="activeArea">
          <i data-feather="search" class="search-field-icon"></i>
          <input type="text"
                 id="sidebar-search"
                 name="sidebar_search"
                 class="sidebar-search-input"
                 placeholder="Search..."
                 autocomplete="off"
                 data-sidebar-search-target="input"
                 data-action="input->sidebar-search#onInput keydown->sidebar-search#onKeydown">
        </div>

        <%# Results popup — positioned via JS as a fixed overlay %>
        <div class="sidebar-search-popup" hidden data-sidebar-search-target="results"></div>

      </div>

      <%# New Session — creates a new RecordingSession %>
      <%= link_to new_recording_session_path, class: "nav-item #{"active" if current_page?(new_recording_session_path)}" do %>
        <i data-feather="mic"></i>
        <span class="label">New session</span>
      <% end %>

      <%# All Sessions — lists the user's past sessions %>
      <%= link_to recording_sessions_path, class: "nav-item #{"active" if current_page?(recording_sessions_path)}" do %>
        <i data-feather="layers"></i>
        <span class="label">Sessions</span>
      <% end %>

      <%# Folders %>
      <%= link_to folders_path, class: "nav-item #{"active" if request.path.start_with?(folders_path)}" do %>
        <i data-feather="folder"></i>
        <span class="label">Folders</span>
      <% end %>

    </nav>

    <%# ── Recent Sessions list ── %>
    <%# @recent_sessions is set by the before_action :set_sidebar_data helper %>
    <div class="recent-section">
      <div class="recent-title">Recent</div>
      <% @recent_sessions&.each do |session| %>

        <div class="recent-item-wrapper">

          <%# Title — Turbo Frame so Rename swaps it inline -%>
          <%= turbo_frame_tag dom_id(session, :sidebar_title), class: "recent-item__frame" do %>
            <%= link_to recording_session_path(session), class: "nav-item recent-item", data: { turbo_frame: "_top", turbo_prefetch: false } do %>
              <span class="status-dot status-dot--<%= session.status %>"></span>
              <span class="label recent-label"><%= session.title.presence || "Untitled" %></span>
            <% end %>
          <% end %>

          <%# 3-dot dropdown -%>
          <div class="dropdown recent-item-menu">
            <button class="recent-menu-btn dropdown-toggle"
                    data-bs-toggle="dropdown"
                    data-bs-auto-close="outside"
                    aria-expanded="false">
              <i class="fa-solid fa-ellipsis"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-end session-dropdown">
              <li>
                <%= link_to edit_recording_session_path(session),
                            data: { turbo_frame: dom_id(session, :sidebar_title) },
                            class: "dropdown-item session-dropdown-item" do %>
                  <i class="fa-solid fa-pencil"></i> Rename
                <% end %>
              </li>

              <%# Add to folder — click expands inline list, stopPropagation keeps dropdown open -%>
              <li>
                <button type="button"
                        class="dropdown-item session-dropdown-item sidebar-folder-toggle"
                        onclick="event.stopPropagation(); this.closest('li').nextElementSibling.hidden = !this.closest('li').nextElementSibling.hidden; this.querySelector('.sidebar-folder-toggle__arrow').classList.toggle('open')">
                  <i class="fa-solid fa-folder-plus"></i>
                  Add to folder
                  <i class="fa-solid fa-chevron-down sidebar-folder-toggle__arrow"></i>
                </button>
              </li>

              <li class="sidebar-folder-list" hidden>
                <% if session.folder.present? %>
                  <%= button_to update_folder_recording_session_path(session),
                                params: { folder_id: "" },
                                method: :patch,
                                class: "dropdown-item session-dropdown-item session-dropdown-item--remove sidebar-folder-option" do %>
                    <i class="fa-solid fa-folder-minus"></i> Remove from folder
                  <% end %>
                <% end %>

                <% @user_folders.reject { |f| f.id == session.folder_id }.each do |folder| %>
                  <%= button_to update_folder_recording_session_path(session),
                                params: { folder_id: folder.id },
                                method: :patch,
                                class: "dropdown-item session-dropdown-item sidebar-folder-option" do %>
                    <i class="fa-solid fa-folder"></i> <%= folder.name %>
                  <% end %>
                <% end %>

                <% if @user_folders.empty? && session.folder.nil? %>
                  <span class="dropdown-item session-dropdown-item disabled sidebar-folder-option">
                    No folders yet
                  </span>
                <% end %>

                <%= link_to new_folder_path(session_id: session.id),
                            class: "dropdown-item session-dropdown-item sidebar-folder-option sidebar-folder-option--new" do %>
                  <i class="fa-solid fa-plus"></i> New folder
                <% end %>
              </li>

              <li><hr class="dropdown-divider"></li>
              <li>
                <%= button_to recording_session_path(session),
                              method: :delete,
                              class: "dropdown-item session-dropdown-item session-dropdown-item--danger",
                              form_class: "session-row__delete-form",
                              data: { turbo_confirm: "Delete \"#{session.title.presence || 'Untitled'}\"? This cannot be undone." } do %>
                  <i class="fa-solid fa-trash"></i> Delete
                <% end %>
              </li>
            </ul>
          </div>

        </div>

      <% end %>
    </div>

  </div>

  <%# ── Bottom: avatar + logout dropdown ── %>
  <div class="sidebar-bottom">
    <div class="avatar-wrapper" id="avatar-toggle">
      <div class="sidebar-avatar">
        <%# Show first letter of username, fallback to email %>
        <%= (current_user.username.presence || current_user.email).first.upcase %>
      </div>
      <%# Show username when sidebar is expanded %>
      <span class="label avatar-name">
        <%= current_user.username.presence || current_user.email.split("@").first %>
      </span>
    </div>

    <%# Dropdown appears above the avatar on click -%>
    <div class="avatar-dropdown" id="avatar-dropdown">
      <%= link_to "Log out",
            destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "avatar-dropdown-item" %>
    </div>
  </div>

</aside>
