<!DOCTYPE html>
<html>
  <head>
    <title>Voxify</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag 'voxify_logo.svg', type: 'image/svg', sizes: '32x32' %>
  </head>

  <body>
    <%# Only show navbar on public pages (no sidebar) %>
    <%= render "shared/navbar" unless show_sidebar? %>

    <%= render "shared/flashes" %>

    <div class="page-wrapper <%= "with-sidebar" if show_sidebar? %>">
      <%# Sidebar only renders for authenticated pages %>
      <% if show_sidebar? %>
        <%= render "shared/sidebar" %>
      <% end %>

      <main class="main-content">
        <%= yield %>
      </main>
    </div>

    <%# Feather icons — re-initialised after every Turbo navigation %>
    <script src="https://unpkg.com/feather-icons"></script>
    <script>
      document.addEventListener("turbo:load", () => feather.replace())
      document.addEventListener("turbo:render", () => feather.replace())
    </script>
  </body>

</html>
