<!DOCTYPE html>
<html>
  <head>
    <title>Voxify</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag 'voxify_logo.svg', type: 'image/svg', sizes: '32x32' %>
  </head>

  <body>
    <%# Only show navbar on public pages (no sidebar) %>
    <%= render "shared/navbar" unless show_sidebar? %>

    <%= render "shared/flashes" %>

    <div class="page-wrapper <%= "with-sidebar" if show_sidebar? %>">
      <%# Sidebar only renders for authenticated pages %>
      <% if show_sidebar? %>
        <%= render "shared/sidebar" %>
      <% end %>

      <main class="main-content">
        <%= yield %>
      </main>
    </div>

    <%# Feather icons — re-initialised after every Turbo navigation %>
    <script src="https://unpkg.com/feather-icons"></script>
    <script>
      function localizeTimestamps() {
        document.querySelectorAll("time[data-localize]").forEach(el => {
          const dt = new Date(el.getAttribute("datetime"))
          if (isNaN(dt.getTime())) return
          const day   = dt.getDate()
          const month = dt.toLocaleString(undefined, { month: "long" })
          const year  = dt.getFullYear()
          const time  = dt.toLocaleString(undefined, { hour: "numeric", minute: "2-digit", timeZoneName: "short" })
          el.textContent = `${day} ${month} ${year} · ${time}`
        })
      }
      function initTooltips() {
        document.querySelectorAll("[data-tooltip-datetime]").forEach(el => {
          const dt = new Date(el.getAttribute("data-tooltip-datetime"))
          if (isNaN(dt.getTime())) return
          const day   = dt.getDate()
          const month = dt.toLocaleString(undefined, { month: "long" })
          const year  = dt.getFullYear()
          const time  = dt.toLocaleString(undefined, { hour: "numeric", minute: "2-digit", timeZoneName: "short" })
          el.setAttribute("title", `${day} ${month} ${year} · ${time}`)
        })
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
          bootstrap.Tooltip.getOrCreateInstance(el, { trigger: "hover" })
        })
      }
      document.addEventListener("turbo:load", () => { feather.replace(); localizeTimestamps(); initTooltips() })
      document.addEventListener("turbo:render", () => { feather.replace(); localizeTimestamps(); initTooltips() })
      document.addEventListener("turbo:before-stream-render", (event) => {
        const original = event.detail.render
        event.detail.render = function(streamElement) {
          // Dispose any tooltips on the element being replaced before it leaves the DOM
          if (streamElement.action === "replace" || streamElement.action === "update") {
            const target = document.getElementById(streamElement.target)
            if (target) {
              bootstrap.Tooltip.getInstance(target)?.dispose()
              target.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
                bootstrap.Tooltip.getInstance(el)?.dispose()
              })
            }
          }
          original(streamElement)
          localizeTimestamps()
          initTooltips()
        }
      })
    </script>
  </body>

</html>
