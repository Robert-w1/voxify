<!DOCTYPE html>
<html>
  <head>
    <title>Voxify</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag 'voxify_logo.svg', type: 'image/svg', sizes: '32x32' %>
  </head>

  <body>
    <%# Only show navbar on public pages (no sidebar) %>
    <%= render "shared/navbar" unless show_sidebar? %>

    <%= render "shared/flashes" %>

    <div class="page-wrapper <%= "with-sidebar" if show_sidebar? %>">
      <%# Sidebar only renders for authenticated pages %>
      <% if show_sidebar? %>
        <%= render "shared/sidebar" %>
      <% end %>

      <main class="main-content">
        <%= yield %>
      </main>
    </div>

    <%# Feather icons — re-initialised after every Turbo navigation %>
    <script src="https://unpkg.com/feather-icons"></script>
    <script>
      function localizeTimestamps() {
        document.querySelectorAll("time[data-localize]").forEach(el => {
          const dt = new Date(el.getAttribute("datetime"))
          if (isNaN(dt.getTime())) return
          el.textContent = dt.toLocaleString(undefined, {
            year: "numeric", month: "short", day: "numeric",
            hour: "numeric", minute: "2-digit", timeZoneName: "short"
          })
        })
      }
      function initTooltips() {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
          bootstrap.Tooltip.getOrCreateInstance(el)
        })
      }
      document.addEventListener("turbo:load", () => { feather.replace(); localizeTimestamps(); initTooltips() })
      document.addEventListener("turbo:render", () => { feather.replace(); localizeTimestamps(); initTooltips() })
    </script>
  </body>

</html>
